          "content": {
            "size": 22646,
            "mimeType": "application/json",
            "text": "{\"branches\":{\"warrior\":[{\"id\":\"w_bash\",\"branch\":\"warrior\",\"tier\":1,\"position\":1,\"name\":\"Удар\",\"max_level\":3,\"current_level\":0,\"waifu_level_req\":1,\"branch_points_req\":0,\"effect_type\":\"melee_dmg_pct\",\"effect_values\":[0.06,0.13,0.22],\"current_effect_value\":null,\"equipment_level_bonus\":0,\"effective_level\":0,\"effective_effect_value\":null,\"next_effective_effect_value\":0.06,\"max_effect_label\":\"+22%\",\"cost_gold\":131,\"description\":\"Увеличивает урон ближнего боя в подземелье, когда тип атаки оружия — melee.\",\"can_learn\":false,\"is_locked\":false,\"learn_block_reason\":\"no_skill_points\"},{\"id\":\"w_tough\",\"branch\":\"warrior\",\"tier\":1,\"position\":2,\"name\":\"Закалка\",\"max_level\":3,\"current_level\":0,\"waifu_level_req\":1,\"branch_points_req\":0,\"effect_type\":\"armor_pct\",\"effect_values\":[0.04,0.09,0.15],\"current_effect_value\":null,\"equipment_level_bonus\":2,\"effective_level\":2,\"effective_effect_value\":0.09,\"next_effective_effect_value\":0.15,\"max_effect_label\":\"+15%\",\"cost_gold\":131,\"description\":\"Увеличивает эффективную броню с надетых предметов (множитель к суммарной броне).\",\"can_learn\":false,\"is_locked\":false,\"learn_block_reason\":\"no_skill_points\"},{\"id\":\"w_cry\",\"branch\":\"warrior\",\"tier\":1,\"position\":3,\"name\":\"Боевой дух\",\"max_level\":3,\"current_level\":0,\"waifu_level_req\":1,\"branch_points_req\":0,\"effect_type\":\"hp_max_pct\",\"effect_values\":[0.03,0.07,0.12],\"current_effect_value\":null,\"equipment_level_bonus\":0,\"effective_level\":0,\"effective_effect_value\":null,\"next_effective_effect_value\":0.03,\"max_effect_label\":\"+12%\",\"cost_gold\":131,\"description\":\"Увеличивает максимум HP основной вайфу.\",\"can_learn\":false,\"is_locked\":false,\"learn_block_reason\":\"no_skill_points\"},{\"id\":\"w_heavy\",\"branch\":\"warrior\",\"tier\":2,\"position\":1,\"name\":\"Тяжёлый удар\",\"max_level\":4,\"current_level\":0,\"waifu_level_req\":10,\"branch_points_req\":5,\"effect_type\":\"stun_chance\",\"effect_values\":[0.08,0.17,0.28,0.42],\"current_effect_value\":null,\"equipment_level_bonus\":0,\"effective_level\":0,\"effective_effect_value\":null,\"next_effective_effect_value\":0.08,\"max_effect_label\":\"+42%\",\"cost_gold\":280,\"description\":\"Шанс оглушения: при срабатывании вы наносите дополнительный урон по монстру.\",\"can_learn\":false,\"is_locked\":true,\"learn_block_reason\":\"locked_branch_points\"},{\"id\":\"w_iron\",\"branch\":\"warrior\",\"tier\":2,\"position\":2,\"name\":\"Железная кожа\",\"max_level\":4,\"current_level\":0,\"waifu_level_req\":10,\"branch_points_req\":5,\"effect_type\":\"dmg_reduce_pct\",\"effect_values\":[0.02,0.04,0.06,0.08],\"current_effect_value\":null,\"equipment_level_bonus\":3,\"effective_level\":3,\"effective_effect_value\":0.06,\"next_effective_effect_value\":0.08,\"max_effect_label\":\"+8%\",\"cost_gold\":280,\"description\":\"Снижает урон от ответного удара монстра; значение также отображается в профиле.\",\"can_learn\":false,\"is_locked\":true,\"learn_block_reason\":\"locked_branch_points\"},{\"id\":\"w_blood\",\"branch\":\"warrior\",\"tier\":2,\"position\":3,\"name\":\"Кров. ярость\",\"max_level\":4,\"current_level\":0,\"waifu_level_req\":10,\"branch_points_req\":5,\"effect_type\":\"low_hp_dmg_pct\",\"effect_values\":[0.1,0.22,0.36,0.54],\"current_effect_value\":null,\"equipment_level_bonus\":0,\"effective_level\":0,\"effective_effect_value\":null,\"next_effective_effect_value\":0.1,\"max_effect_label\":\"+54%\",\"cost_gold\":280,\"description\":\"Пока текущее HP ниже 50% от максимума, ваш урон сообщений в бою выше.\",\"can_learn\":false,\"is_locked\":true,\"learn_block_reason\":\"locked_branch_points\"},{\"id\":\"w_berserk\",\"branch\":\"warrior\",\"tier\":3,\"position\":1,\"name\":\"Берсерк\",\"max_level\":4,\"current_level\":0,\"waifu_level_req\":25,\"branch_points_req\":15,\"effect_type\":\"hp_loss_dmg_pct\",\"effect_values\":[0.15,0.32,0.