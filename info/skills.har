            "text": "{\"player_id\":305174198,\"act\":4,\"max_act\":4,\"gold\":26900,\"skill_points\":0,\"protection_stones\":0,\"enchant_dust\":527,\"caravan_travel_costs\":[50,200,500,1200,2500],\"main_waifu\":{\"id\":29,\"name\":\"Стонкс-тянка\",\"race\":4,\"class\":7,\"level\":33,\"experience\":217322,\"strength\":10,\"agility\":10,\"intelligence\":38,\"endurance\":15,\"charm\":14,\"luck\":13,\"stat_points\":0,\"current_hp\":627,\"max_hp\":900,\"base_strength\":null,\"base_agility\":null,\"base_intelligence\":null,\"base_endurance\":null,\"base_charm\":null,\"base_luck\":null,\"bonus_strength\":null,\"bonus_agility\":null,\"bonus_intelligence\":null,\"bonus_endurance\":null,\"bonus_charm\":null,\"bonus_luck\":null,\"passive_main_stats_flat\":0,\"race_flat_bonuses\":{},\"class_flat_bonuses\":{},\"portrait_url\":null,\"paperdoll_url\":null,\"paperdoll_generations_remaining\":0,\"bio\":\"Стонкс-тянка — изгнанный с небес ангел, чьи белоснежные крылья потускнели, заставив её сменить святое служение на искусство выгодной торговли среди сырых дубрав Вердгленда. Встретив героя в утреннем мареве, которое вопреки законам природы не желает таять, она решает сопровождать его, ведь нездоровая порча в тумане грозит уничтожить не только её редкие товары, но и само будущее этого мира.\"},\"main_waifu_details\":null,\"equipment\":[],\"tutorial\":{\"version\":1,\"completed\":{\"shop\":\"2026-05-29T17:28:13+00:00\",\"guild\":\"2026-05-29T17:34:20+00:00\",\"intro\":\"2026-05-29T17:03:43+00:00\",\"tavern\":\"2026-05-29T17:04:07+00:00\",\"caravan\":\"2026-05-29T17:04:10+00:00\",\"dungeons\":\"2026-05-29T17:03:54+00:00\",\"training\":\"2026-05-29T17:25:56+00:00\",\"waifu_gen\":\"2026-05-29T12:30:01+00:00\"},\"skipped\":false,\"intro_reward_claimed\":true}}"
