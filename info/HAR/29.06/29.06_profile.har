            "mimeType": "application/json",
            "text": "{\"player_id\":305174198,\"act\":4,\"max_act\":4,\"gold\":28669,\"skill_points\":0,\"protection_stones\":0,\"enchant_dust\":487,\"caravan_travel_costs\":[50,200,500,1200,2500],\"main_waifu\":{\"id\":29,\"name\":\"Стонкс-тянка\",\"race\":4,\"class\":7,\"level\":38,\"experience\":315893,\"strength\":18,\"agility\":11,\"intelligence\":65,\"endurance\":32,\"charm\":14,\"luck\":14,\"stat_points\":0,\"current_hp\":945,\"max_hp\":1131,\"base_strength\":10,\"base_agility\":10,\"base_intelligence\":43,\"base_endurance\":15,\"base_charm\":14,\"base_luck\":13,\"bonus_strength\":8,\"bonus_agility\":1,\"bonus_intelligence\":22,\"bonus_endurance\":17,\"bonus_charm\":0,\"bonus_luck\":1,\"passive_main_stats_flat\":0,\"race_flat_bonuses\":{\"charm\":2,\"intelligence\":1,\"luck\":1},\"class_flat_bonuses\":{\"charm\":2,\"luck\":2},\"portrait_url\":\"/static/game/waifus/portraits/305174198.webp?v=1\",\"paperdoll_url\":\"/static/game/waifus/paperdolls/305174198.webp?v=2\",\"paperdoll_generations_remaining\":0,\"bio\":\"Стонкс-тянка — изгнанный с небес ангел, чьи белоснежные крылья потускнели, заставив её сменить святое служение на искусство выгодной торговли среди сырых дубрав Вердгленда. Встретив героя в утреннем мареве, которое вопреки законам природы не желает таять, она решает сопровождать его, ведь нездоровая порча в тумане грозит уничтожить не только её редкие товары, но и само будущее этого мира.\"},\"main_waifu_details\":{\"hp_current\":945,\"hp_max\":1178,\"armor\":149,\"melee_damage\":46,\"melee_damage_min\":46,\"melee_damage_max\":46,\"ranged_damage\":34,\"ranged_damage_min\":34,\"ranged_damage_max\":34,\"magic_damage\":748,\"magic_damage_min\":728,\"magic_damage_max\":768,\"crit_chance\":6.86,\"dodge_chance\":9.08,\"full_evade_chance\":14.0,\"defense\":0,\"merchant_discount\":17.3,\"magic_find_pct\":1.4,\"magic_find_blend_pct\":0.56},\"equipment\":[{\"id\":6108,\"slot\":\"ring_1\",\"name\":\"Длань сокрушителя владык\",\"display_name\":\"Длань сокрушителя