# Waifu Bot — Redis production snippets (merge into redis.conf)
# See docs/STAGE1_INFRA.md

appendonly yes
appendfsync everysec
auto-aof-rewrite-percentage 100
auto-aof-rewrite-min-size 64mb

# Optional: cap memory for chat/GD buffers (adjust per VPS RAM)
# maxmemory 512mb
# maxmemory-policy noeviction
