; Waifu Bot — PgBouncer example (transaction pooling for async SQLAlchemy)
; Install path: /etc/pgbouncer/pgbouncer.ini

[databases]
waifu = host=127.0.0.1 port=5432 dbname=waifu

[pgbouncer]
listen_addr = 127.0.0.1
listen_port = 6432
auth_type = md5
auth_file = /etc/pgbouncer/userlist.txt
admin_users = postgres
pool_mode = transaction
max_client_conn = 200
default_pool_size = 20
min_pool_size = 5
reserve_pool_size = 5
server_reset_query = DISCARD ALL
ignore_startup_parameters = extra_float_digits
